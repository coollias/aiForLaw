# AI 法律助手 — 环境配置
# 复制此文件为 .env 并填入实际值

# 访问密码（前端登录用）
ADMIN_USERNAME=loveHmt
ACCESS_PASSWORD=your_password_here

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
# 法规/案例工作台的高判断步骤：检索计划、案例筛选、法条筛选、最终回答
RESEARCH_PRO_MODEL=deepseek-v4-pro
# 合同审查：检索关键词用 flash，最终审查和追问用 pro
CONTRACT_REFERENCE_QUERY_MODEL=deepseek-v4-flash
CONTRACT_REVIEW_MODEL=deepseek-v4-pro
CONTRACT_REVIEW_MAX_INPUT_CHARS=180000
CONTRACT_REVIEW_CHUNK_CHARS=42000

# 元典 MCP 配置
YUANDIAN_MCP_ENABLED=true
YUANDIAN_API_KEY=sk-your-yuandian-key-here

# MinerU PDF 解析配置
MINERU_API_TOKEN=your_mineru_api_token_here
MINERU_API_BASE_URL=https://mineru.net
MINERU_MODEL_VERSION=vlm
MINERU_POLL_INTERVAL_SECONDS=3
MINERU_POLL_TIMEOUT_SECONDS=180
MINERU_RETRY_INSECURE_SSL=true

# 合同审查上传文件保存目录（可选，生产环境建议放到 release 目录之外）
CONTRACT_UPLOAD_DIR=/opt/ai-law-helper/data/contract_reviews

# MySQL 数据库配置
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=ai_law_helper

# 会话配置
SESSION_SECRET_KEY=change-this-to-a-random-string
SESSION_MAX_AGE_HOURS=24
